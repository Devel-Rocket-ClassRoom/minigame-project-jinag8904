# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore

/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
/[Mm]emoryCaptures/

# Recordings can get excessive in size
/[Rr]ecordings/

# Crash Reports
/[Cc]rash[Rr]eports/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider solution file
/[Aa]ssets/Rider*

# Visual Studio cache directory
.vs/

# Gradle cache directory
.gradle/

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app
Build.zip

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/**/[Cc]atalog*.json
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/**/[Cc]atalog*.hash

# Rule Based Packing
/[Aa]ssets/[Ss]tream[Ii]ng[Aa]ssets/aa.meta
/[Aa]ssets/[Ss]tream[Ii]ng[Aa]ssets/aa/

# TextMeshPro cache
/[Aa]ssets/TextMesh*Pro/Examples*
/[Aa]ssets/TextMesh*Pro/Resources/Fonts & Materials/

# Firebase Unity SDK — 용량(100MB+ 단일 파일)이 GitHub 한도 초과.
# 커밋하지 않음. 클론 후 .unitypackage(FirebaseAuth/FirebaseDatabase)로 직접 임포트.
/[Aa]ssets/Firebase/
/[Aa]ssets/Firebase.meta
/[Aa]ssets/ExternalDependencyManager/
/[Aa]ssets/ExternalDependencyManager.meta
/[Aa]ssets/Plugins/iOS/
/[Aa]ssets/Plugins/iOS.meta
/[Aa]ssets/Plugins/tvOS/
/[Aa]ssets/Plugins/tvOS.meta
/[Aa]ssets/Editor Default Resources/
/[Aa]ssets/Editor Default Resources.meta
/[Aa]ssets/StreamingAssets/
/[Aa]ssets/StreamingAssets.meta
